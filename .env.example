# Optional: shared jobs for the whole team (Supabase Postgres).
# 1. Create a project at https://supabase.com
# 2. Run SQL from supabase/jobs_list.sql in the SQL Editor
# 3. Copy Project URL and anon public key from Project Settings → API Keys
#
# Copy this file to `.env` and fill in real values (never commit `.env`).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# If unset, jobs stay in browser localStorage only (per device).
